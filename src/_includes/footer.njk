<footer class="bg-navy-light border-t border-white/5">

  <!-- Map + Service Areas -->
  <div class="border-b border-white/5">
    <div class="max-w-6xl mx-auto px-5 py-12">
      <div class="grid md:grid-cols-2 gap-10 lg:gap-16">

        <!-- Map -->
        <div class="reveal">
          <h3 class="font-serif text-xl text-white mb-4">Our Service Area</h3>
          <div class="rounded-xl overflow-hidden border border-white/10 aspect-[16/10]">
            <iframe
              title="{{ site.businessName }} service area — {{ site.serviceArea }}"
              src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d93222.39383386498!2d-79.87!3d43.25!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sca!4v1710374400000"
              width="100%"
              height="100%"
              style="border:0; filter: grayscale(0.6) contrast(1.1) brightness(0.85);"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade">
            </iframe>
          </div>
        </div>

        <!-- Neighbourhoods -->
        <div class="reveal stagger-1">
          <h3 class="font-serif text-xl text-white mb-4">Neighbourhoods We Serve</h3>
          <p class="text-text-muted text-sm mb-6">Sub-metering installation for landlords across Hamilton, Burlington, and surrounding communities.</p>

          <div class="grid grid-cols-2 gap-x-8 gap-y-1">
            <div class="mb-4">
              <p class="text-emerald text-xs font-semibold uppercase tracking-wider mb-2">Hamilton</p>
              <ul class="space-y-1.5 text-text-muted text-sm">
                {%- for n in site.neighbourhoods.hamilton %}
                <li>{{ n }}</li>
                {%- endfor %}
              </ul>
            </div>

            <div class="mb-4">
              <p class="text-emerald text-xs font-semibold uppercase tracking-wider mb-2">Burlington</p>
              <ul class="space-y-1.5 text-text-muted text-sm">
                {%- for n in site.neighbourhoods.burlington %}
                <li>{{ n }}</li>
                {%- endfor %}
              </ul>
            </div>
          </div>

          <p class="text-text-muted/60 text-xs mt-4">Don't see your area? <a href="tel:{{ site.phoneLink }}" class="text-emerald hover:underline">Call us</a> — we likely cover it.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer bottom -->
  <div class="max-w-6xl mx-auto px-5 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <div class="flex items-center gap-2.5 mb-1">
          <svg width="28" height="28" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="1" y="1" width="34" height="34" rx="8" fill="#0F172A" stroke="#10B981" stroke-width="1.5"/>
            <path d="M20.5 5L11 19.5h6L14.5 31 25 16.5h-6L20.5 5z" fill="#10B981"/>
            <line x1="8" y1="8" x2="10" y2="10" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
            <line x1="28" y1="8" x2="26" y2="10" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
            <line x1="8" y1="28" x2="10" y2="26" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
            <line x1="28" y1="28" x2="26" y2="26" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
          </svg>
          <span class="font-serif text-xl text-white">{{ site.businessName }}</span>
        </div>
        <p class="text-text-muted text-sm">{{ site.tagline }} &middot; {{ site.serviceArea }}</p>
      </div>
      <div class="text-center sm:text-right">
        <p class="text-text-muted text-sm mb-1">{{ site.license }}</p>
        <a href="tel:{{ site.phoneLink }}" class="text-emerald text-sm font-medium hover:underline">{{ site.phoneDisplay }}</a>
      </div>
    </div>
    <div class="border-t border-white/5 mt-8 pt-6 text-center">
      <p class="text-text-muted/60 text-xs">&copy; {{ site.copyrightYear }} {{ site.businessName }}. All rights reserved.</p>
    </div>
  </div>
</footer>
