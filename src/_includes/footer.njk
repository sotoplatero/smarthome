<footer class="bg-navy-light border-t border-white/5">
  <div class="max-w-6xl mx-auto px-5 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <div class="flex items-center gap-2.5 mb-1">
          <svg width="28" height="28" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect x="1" y="1" width="34" height="34" rx="8" fill="#0F172A" stroke="#10B981" stroke-width="1.5"/>
            <path d="M20.5 5L11 19.5h6L14.5 31 25 16.5h-6L20.5 5z" fill="#10B981"/>
            <line x1="8" y1="8" x2="10" y2="10" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
            <line x1="28" y1="8" x2="26" y2="10" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
            <line x1="8" y1="28" x2="10" y2="26" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
            <line x1="28" y1="28" x2="26" y2="26" stroke="#10B981" stroke-width="1" stroke-linecap="round" opacity="0.4"/>
          </svg>
          <span class="font-serif text-xl text-white">{{ site.businessName }}</span>
        </div>
        <p class="text-text-muted text-sm">{{ site.tagline }} &middot; {{ site.serviceArea }}</p>
      </div>
      <div class="text-center sm:text-right">
        <a href="tel:{{ site.phoneLink }}" class="text-emerald text-sm font-medium hover:underline">{{ site.phoneDisplay }}</a>
      </div>
    </div>
    <div class="border-t border-white/5 mt-8 pt-6 text-center">
      <p class="text-text-muted/60 text-xs">&copy; {{ site.copyrightYear }} {{ site.businessName }}. All rights reserved.</p>
    </div>
  </div>
</footer>
