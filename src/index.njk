---
layout: base.njk
---
{% set waUrl = site | waUrl %}

{% include "nav.njk" %}
{% include "hero.njk" %}

{# ========== TRUST BAR ========== #}
{% if site.showTrustBar %}
<section class="bg-navy-light border-y border-white/5 py-6">
  <div class="max-w-5xl mx-auto px-5">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div class="reveal stagger-1">
        <p class="text-2xl sm:text-3xl font-bold text-emerald">{{ site.stats.properties }}</p>
        <p class="text-text-muted text-xs sm:text-sm mt-1">Properties Metered</p>
      </div>
      <div class="reveal stagger-2">
        <p class="text-2xl sm:text-3xl font-bold text-emerald">{{ site.stats.units }}</p>
        <p class="text-text-muted text-xs sm:text-sm mt-1">Units Installed</p>
      </div>
      <div class="reveal stagger-3">
        <p class="text-2xl sm:text-3xl font-bold text-white">{{ site.stats.monthlyFees }}</p>
        <p class="text-text-muted text-xs sm:text-sm mt-1">Monthly Fees</p>
      </div>
      <div class="reveal stagger-4">
        <p class="text-2xl sm:text-3xl font-bold text-white">{{ site.stats.installTime }}</p>
        <p class="text-text-muted text-xs sm:text-sm mt-1">Typical Install</p>
      </div>
    </div>
  </div>
</section>
{% endif %}

{# ========== PROBLEM SECTION ========== #}
<section class="py-20 sm:py-28 bg-surface-white">
  <div class="max-w-6xl mx-auto px-5">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <div class="accent-line mx-auto mb-6 reveal"></div>
      <h2 class="reveal font-serif text-3xl sm:text-4xl md:text-[2.75rem] text-navy leading-tight mb-5" style="text-wrap: balance;">
        Sound Familiar?
      </h2>
      <p class="reveal stagger-1 text-text-muted text-lg">
        If your building has one meter for multiple units, you already know these problems.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="reveal stagger-1 group bg-surface rounded-2xl p-7 border border-slate-100 hover:border-emerald/30 hover:shadow-lg hover:shadow-emerald/5 transition-colors transition-shadow duration-300">
        <div class="w-12 h-12 rounded-xl bg-emerald/10 flex items-center justify-center mb-5 group-hover:bg-emerald/20 transition-colors">
          <svg class="w-6 h-6 text-emerald" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg>
        </div>
        <h3 class="font-semibold text-navy text-lg mb-2">"My hydro bill keeps climbing"</h3>
        <p class="text-text-muted text-sm leading-relaxed">You pay more every quarter but can't tell which unit is driving the cost up.</p>
      </div>

      <div class="reveal stagger-2 group bg-surface rounded-2xl p-7 border border-slate-100 hover:border-emerald/30 hover:shadow-lg hover:shadow-emerald/5 transition-colors transition-shadow duration-300">
        <div class="w-12 h-12 rounded-xl bg-emerald/10 flex items-center justify-center mb-5 group-hover:bg-emerald/20 transition-colors">
          <svg class="w-6 h-6 text-emerald" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"/></svg>
        </div>
        <h3 class="font-semibold text-navy text-lg mb-2">"Tenants blast heat all winter"</h3>
        <p class="text-text-muted text-sm leading-relaxed">When electricity is "included," tenants have zero reason to conserve. You absorb the waste.</p>
      </div>

      <div class="reveal stagger-3 group bg-surface rounded-2xl p-7 border border-slate-100 hover:border-emerald/30 hover:shadow-lg hover:shadow-emerald/5 transition-colors transition-shadow duration-300">
        <div class="w-12 h-12 rounded-xl bg-emerald/10 flex items-center justify-center mb-5 group-hover:bg-emerald/20 transition-colors">
          <svg class="w-6 h-6 text-emerald" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg>
        </div>
        <h3 class="font-semibold text-navy text-lg mb-2">"Splitting the bill causes fights"</h3>
        <p class="text-text-muted text-sm leading-relaxed">Even splits are never fair. Someone always uses more, and everyone resents the arrangement.</p>
      </div>

      <div class="reveal stagger-4 group bg-surface rounded-2xl p-7 border border-slate-100 hover:border-emerald/30 hover:shadow-lg hover:shadow-emerald/5 transition-colors transition-shadow duration-300">
        <div class="w-12 h-12 rounded-xl bg-emerald/10 flex items-center justify-center mb-5 group-hover:bg-emerald/20 transition-colors">
          <svg class="w-6 h-6 text-emerald" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/></svg>
        </div>
        <h3 class="font-semibold text-navy text-lg mb-2">"I can't raise rent enough"</h3>
        <p class="text-text-muted text-sm leading-relaxed">Rent increases are capped, but hydro keeps rising. The gap between what you charge and what you pay grows every year.</p>
      </div>
    </div>

    <p class="reveal text-center text-navy font-semibold mt-12 text-lg">
      One shared meter always means <span class="text-emerald">you</span> pay for someone else's hydro.
    </p>
  </div>
</section>

{# ========== HOW IT WORKS ========== #}
<section class="relative py-20 sm:py-28 bg-navy grain overflow-hidden">
  <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-emerald/[0.03] to-transparent pointer-events-none"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-5">
    <div class="text-center mb-16">
      <div class="accent-line mx-auto mb-6 reveal"></div>
      <h2 class="reveal font-serif text-3xl sm:text-4xl md:text-[2.75rem] text-white leading-tight mb-5" style="text-wrap: balance;">
        Three Steps to Stop Subsidizing Hydro
      </h2>
      <p class="reveal stagger-1 text-text-muted text-lg max-w-xl mx-auto">
        No contracts. No monthly fees. One-time install.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8 md:gap-6">
      <div class="reveal stagger-1 relative text-center step-connector">
        <div class="w-12 h-12 rounded-full bg-emerald text-navy font-bold text-xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-emerald/20">1</div>
        <h3 class="font-semibold text-white text-lg mb-2">Free On-Site Quote</h3>
        <p class="text-text-muted text-sm leading-relaxed">We inspect your property and give you a flat-rate price the same day. No cost, no commitment.</p>
      </div>
      <div class="reveal stagger-2 relative text-center step-connector">
        <div class="w-12 h-12 rounded-full bg-emerald text-navy font-bold text-xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-emerald/20">2</div>
        <h3 class="font-semibold text-white text-lg mb-2">One-Day Installation</h3>
        <p class="text-text-muted text-sm leading-relaxed">Certified meters clip onto existing wiring. No rewiring, no damage, no major disruption.</p>
      </div>
      <div class="reveal stagger-3 relative text-center step-connector">
        <div class="w-12 h-12 rounded-full bg-emerald text-navy font-bold text-xl flex items-center justify-center mx-auto mb-5 shadow-lg shadow-emerald/20">3</div>
        <h3 class="font-semibold text-white text-lg mb-2">Monitor & Save</h3>
        <p class="text-text-muted text-sm leading-relaxed">Track every unit's usage online. Tenants pay their share. You keep your money.</p>
      </div>
    </div>

    <p class="reveal text-center text-emerald font-semibold mt-12 bg-emerald/10 rounded-xl py-4 px-6 max-w-md mx-auto text-sm">
      Most properties are up and running in 2–3 weeks
    </p>
  </div>
</section>

{# ========== PROCESS DETAIL 1: INSPECTION ========== #}
<section class="py-20 sm:py-24 bg-surface-white">
  <div class="max-w-6xl mx-auto px-5">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
          <img src="{{ site.images.inspection }}" alt="Modern residential property interior" width="800" height="600" loading="lazy" class="w-full h-full object-cover">
          <div class="absolute inset-0 bg-gradient-to-t from-navy/30 to-transparent"></div>
        </div>
      </div>
      <div>
        <div class="reveal inline-flex items-center gap-2 bg-emerald/10 text-emerald text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
          <span class="w-6 h-6 rounded-full bg-emerald text-navy text-xs font-bold flex items-center justify-center">1</span>
          Free Quote
        </div>
        <h2 class="reveal stagger-1 font-serif text-3xl sm:text-4xl text-navy leading-tight mb-5">
          We Come to You. You Pay Nothing.
        </h2>
        <p class="reveal stagger-2 text-text-muted text-lg leading-relaxed mb-6">
          A technician visits your property, checks your electrical panel, and tells you on the spot whether sub-metering will work. If it does, you get a flat-rate quote before we leave. If it doesn't, you've lost nothing but 30 minutes.
        </p>
        <ul class="space-y-3">
          <li class="reveal stagger-2 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>No deposit, no credit card</strong> — the inspection is genuinely free</span>
          </li>
          <li class="reveal stagger-3 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Flat-rate quote same day</strong> — you know the exact cost before you decide anything</span>
          </li>
          <li class="reveal stagger-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Evenings & weekends available</strong> — we work around your schedule, not ours</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

{# ========== PROCESS DETAIL 2: INSTALLATION ========== #}
<section class="py-20 sm:py-24 bg-surface">
  <div class="max-w-6xl mx-auto px-5">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="order-2 md:order-1">
        <div class="reveal inline-flex items-center gap-2 bg-emerald/10 text-emerald text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
          <span class="w-6 h-6 rounded-full bg-emerald text-navy text-xs font-bold flex items-center justify-center">2</span>
          Installation
        </div>
        <h2 class="reveal stagger-1 font-serif text-3xl sm:text-4xl text-navy leading-tight mb-5">
          No Rewiring. No Holes. No Damage to Your Property.
        </h2>
        <p class="reveal stagger-2 text-text-muted text-lg leading-relaxed mb-6">
          Our meters use current transformers that clip around existing wires. We don't cut, splice, or modify your electrical system. If you ever want to remove them, your panel goes back to exactly how it was.
        </p>
        <ul class="space-y-3">
          <li class="reveal stagger-2 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Your existing wiring stays untouched</strong> — meters clip on, nothing gets cut or spliced</span>
          </li>
          <li class="reveal stagger-3 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Finished in 4–6 hours</strong> — power off for under 1 hour total</span>
          </li>
          <li class="reveal stagger-3 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>ESA-certified electricians</strong> — licensed, insured, full liability coverage</span>
          </li>
          <li class="reveal stagger-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Measurement Canada certified</strong> — meters are legally billable from day one</span>
          </li>
        </ul>
      </div>
      <div class="reveal order-1 md:order-2">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
          <img src="{{ site.images.installation }}" alt="Licensed electrician working on electrical panel" width="800" height="600" loading="lazy" class="w-full h-full object-cover">
          <div class="absolute inset-0 bg-gradient-to-t from-navy/30 to-transparent"></div>
          <div class="absolute bottom-5 left-5 right-5">
            <p class="text-white text-xs font-medium bg-navy/70 backdrop-blur-sm rounded-lg px-3 py-2 border border-white/10">
              <span class="text-emerald font-bold">Non-invasive:</span> current transformers clip on — fully reversible, zero damage.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{# ========== PROCESS DETAIL 3: MONITORING ========== #}
<section class="py-20 sm:py-24 bg-surface-white">
  <div class="max-w-6xl mx-auto px-5">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div class="reveal">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]">
          <img src="{{ site.images.monitoring }}" alt="Analytics dashboard showing real-time energy data" width="800" height="600" loading="lazy" class="w-full h-full object-cover">
          <div class="absolute inset-0 bg-gradient-to-t from-navy/30 to-transparent"></div>
        </div>
      </div>
      <div>
        <div class="reveal inline-flex items-center gap-2 bg-emerald/10 text-emerald text-sm font-semibold px-4 py-1.5 rounded-full mb-5">
          <span class="w-6 h-6 rounded-full bg-emerald text-navy text-xs font-bold flex items-center justify-center">3</span>
          Monitoring
        </div>
        <h2 class="reveal stagger-1 font-serif text-3xl sm:text-4xl text-navy leading-tight mb-5">
          See Every Unit's Usage From Your Phone
        </h2>
        <p class="reveal stagger-2 text-text-muted text-lg leading-relaxed mb-6">
          Each meter connects to the internet and pushes data to a live dashboard. You see exactly what every unit consumes — hourly, daily, monthly — without setting foot in the building.
        </p>
        <ul class="space-y-3">
          <li class="reveal stagger-2 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>24/7 online dashboard</strong> — all units in one screen, phone or desktop</span>
          </li>
          <li class="reveal stagger-3 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Monthly reports ready to forward</strong> — PDF summaries for billing or lease attachments</span>
          </li>
          <li class="reveal stagger-3 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Spike alerts</strong> — get notified if a unit's consumption jumps unexpectedly</span>
          </li>
          <li class="reveal stagger-4 flex items-start gap-3">
            <svg class="w-5 h-5 text-emerald mt-0.5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
            <span class="text-navy text-sm"><strong>Tenant access</strong> — each tenant sees their own usage, which ends "it wasn't me" disputes</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

{# ========== TESTIMONIALS ========== #}
{% if site.showTestimonials %}
<section class="py-16 sm:py-20 bg-surface">
  <div class="max-w-5xl mx-auto px-5">
    <div class="text-center mb-12">
      <div class="accent-line mx-auto mb-6 reveal"></div>
      <h2 class="reveal font-serif text-3xl sm:text-4xl text-navy leading-tight" style="text-wrap: balance;">
        What Landlords Say
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {% for t in site.testimonials %}
      <div class="reveal stagger-{{ loop.index }} bg-surface-white rounded-2xl p-8 border border-slate-100">
        <div class="flex gap-1 mb-4">
          {% for i in range(0, t.stars) %}
          <svg class="w-5 h-5 text-amber" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {% endfor %}
        </div>
        <p class="text-navy leading-relaxed mb-5">"{{ t.quote }}"</p>
        <div>
          <p class="font-semibold text-navy text-sm">{{ t.name }}</p>
          <p class="text-text-muted text-xs">{{ t.detail }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

{# ========== FAQ ========== #}
<section class="py-20 sm:py-28 bg-surface-white">
  <div class="max-w-2xl mx-auto px-5">
    <div class="text-center mb-14">
      <div class="accent-line mx-auto mb-6 reveal"></div>
      <h2 class="reveal font-serif text-3xl sm:text-4xl text-navy leading-tight">
        Common Questions
      </h2>
    </div>

    <div class="space-y-3">
      {% for item in site.faq %}
      <div class="reveal stagger-{{ loop.index }} faq-item bg-surface rounded-xl border border-slate-100 overflow-hidden">
        <button class="faq-toggle w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
          <span class="font-semibold text-navy pr-4">{{ item.question }}</span>
          <span class="faq-icon text-emerald text-2xl font-light shrink-0">+</span>
        </button>
        <div class="faq-answer px-6">
          <p class="text-text-muted text-sm leading-relaxed pb-6">
            {{ item.answer | safe }}
          </p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

{# ========== FINAL CTA ========== #}
<section class="relative py-20 sm:py-28 bg-navy grain overflow-hidden">
  <div class="absolute inset-0">
    <img src="{{ site.images.cta }}" alt="Hamilton city skyline" width="1920" height="1080" loading="lazy" class="w-full h-full object-cover opacity-15">
  </div>
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-96 h-96 bg-emerald/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-5 text-center">
    <div class="accent-line mx-auto mb-6 reveal"></div>
    <h2 class="reveal font-serif text-3xl sm:text-4xl md:text-5xl text-white leading-tight mb-5" style="text-wrap: balance;">
      Every Month You Wait Costs You $300+
    </h2>
